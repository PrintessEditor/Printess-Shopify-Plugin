{% comment %}
    Renders the Printess initialization code
    Version 1.0

    Accepts:
    - shopToken: {String} The printess shop token.
    - graphQlToken: {String} The app auth token that is used to access the shopify graphql api's
    - graphQlLanguage: {String} The language that should be used by graphql to translate product option values. Keep empty for not using a language (default)
    - apiDomain: {String} The domain name that should be used to connect to the Printess api
    - editorDomain: {String} The domain that should be used to connect to the Printess editor
    - editorVersion: {String} Provide the version you want to pin the editor to. Keep empty for current release version. Example "v/nightly"
    - importProductOptionsFromVariantId: {Boolean} In case the used Variant selector control does not use inputs for the selected product options, force the printess integration to use the id input field of the product page
    - cssAddToBasketButtonSelector: {String}: The css selector that selects the current add to basket button
    - ignoreDataOptionIndex: {Boolean} false
    - attachParams: {String}
    - loadingButtonText: {String}
    - designButtonText:  {String}
    - designButtonClasses:  {String}
    - disableCssLoading: {Boolean}
    - formInsertPosition: {Number} In case a product does not have a variant selector, the child position inside the product info section at which the slim ui should be added to
    - disableProductIntegration: { Boolean } The Product page integration should be loaded. Default value true.
    - disableSettingsIntegration: { Boolean } The settings object should be rendered. Default value is true
    - disableCartIntegration: { Boolean } The cart integration should be rendered. Default value is true.
    - scriptBlockId: {String}
    - hasFullEditor: {Boolean}
    - advancedButtonClasses: {String}
    - additionalProductMetaFields: {String}
    - customerId: {string}
    - supportsSaving: {Boolean}
    - ignoreFirstRenderCall {Boolean} Update Thumbnails on SlimUi only if customer changed something
    - redirectToCartAfterAddToBasketClick {Boolean} Redirect to the basket after adding the item to the cart (Default true)

    Usage:
    {% render 'printess-init',
      shopToken: "xyz",
      graphQlToken: "yz1",
      graphQlLanguage: "",
      apiDomain: "",
      editorDomain: "",
      editorVersion: "",
      importProductOptionsFromVariantId: false,
      ignoreDataOptionIndex: false,
      attachParams: "",
      loadingButtonText: "Loading",
      designButtonText:  "Design now",
      designButtonClasses:  "",
      cssAddToBasketButtonSelector: 'button[type="submit"][name="add"], button.product-form__add-button[data-action="add-to-cart"],button#AddToCart,.add-to-cart-button,#AddToCart',
      disableCssLoading: false,
      formInsertPosition: 3,
      hasFullEditor: false,
      additionalProductMetaFields: "custom.meta1,custom.meta2",
      customerId: "2010a",
      supportsSaving: true,
      ignoreFirstRenderCall: false,
      redirectToCartAfterAddToBasketClick: true
    %}
{% endcomment %}

{% if disableCssLoading != true %}
  <link rel="stylesheet" type="text/css" href="{%if integrationUrl != blank %}{{integrationUrl}}{%else%}https://editor.printess.com/shopify-panelui/{%endif%}printessEditor.css">
  <link rel="stylesheet" type="text/css" href="{%if integrationUrl != blank %}{{integrationUrl}}{%else%}https://editor.printess.com/shopify-panelui/{%endif%}printessSlimUi.css">
{% endif %}

{% if customerId != blank %}
  {% assign customer_id = customerId %}
{% else %}
  {% if customer %}
    {% assign customer_id = shop.permanent_domain | append: "_" | append: customer.id | sha256 %}
  {% else %}
    {% assign customer_id = "" %}
  {% endif %}
{% endif %}

<script id="{% if scriptBlockId == blank%}printess-integration{% else %}{{scriptBlockId}}{% endif %}">
{% if disableSettingsIntegration != true %}
var printessSettings = {
  integrateSlimUi: {{ integrate_printess_slimui | json }},
  integrateEditor: {{ integrate_printess_full_editor | json }},
  shopToken: {{ shopToken | json}} || {{ shop.metafields.printess.shopToken.value | json }},
  apiDomain: {{ apiDomain | json }} || "api.printess.com",
  editorDomain: {{ editorDomain | json }} || "editor.printess.com",
  editorVersion: {{ editorVersion | json }} || "",
  graphQlToken: {{ graphQlToken | json}} || "{{ shop.permanent_domain }}",
  graphQlLanguage: {{ graphQlLanguage | json}},
  importProductOptionsFromVariantId: {% if importProductOptionsFromVariantId != blank  %} {{ importProductOptionsFromVariantId | json }} {% else %} false {% endif %},
  ignoreDataOptionIndex: {% if ignoreDataOptionIndex != blank  %} {{ ignoreDataOptionIndex | json }} {% else %} false {% endif %},
  attachParams: ({{ attachParams | json }}) ? JSON.parse({{ attachParams | json }}) : null,
  designButtonClasses: {{ integrationButtonClasses | json }} || "",
  cartButtonClasses: {{cartButtonClasses | json }} || "",
  advancedButtonClasses: {{ advancedButtonClasses | json }} || "",
  integrationUrl: "{%if integrationUrl != blank %}{{integrationUrl}}{%else%}https://editor.printess.com/shopify-panelui/{%endif%}",
  additionalProductMetaFields: {{ additionalProductMetaFields | json }} || "",
  customerId: {% if customer_id == blank %} null {% else %} {{ customer_id | json }} {% endif %},
  customerIsLoggedIn: {% if customer_id == blank %} false {% else %} true {% endif %},
  internalShopDomain: {{ shop.permanent_domain | json }},
  loginUrl: {{ routes.storefront_login_url | json }},
  registrationUrl: {{ routes.account_register_url | json }},
  supportsSaving: {% if supportsSaving == true %}true{%else%}false{%endif%},
  uiSelectors:  {
    cssProductContainerSelector: {{ cssProductContainerSelector | json }} || "",
    cssProductInfoSelector: {{ cssProductInfoSelector | json }} || "",
    cssProductMediaSelector: {{ cssProductMediaSelector | json }} || "",
    cssImageSelector: {{ cssImageSelector | json }} || "",
    cssPriceTextSelector: {{ cssPriceTextSelector | json }} || "",
    cssProductFormSelector: {{ cssProductFormSelector | json }} || "",
    cssProductIdSelector: {{ cssProductIdSelector | json }} || "",
    cssProgressIndicatorSelector: {{ cssProgressIndicatorSelector | json }} || "",
    cssAddToBasketButtonSelector: {{ cssAddToBasketButtonSelector | json }} || "button[type=\"submit\"][name=\"add\"], button.product-form__add-button[data-action=\"add-to-cart\"],button#AddToCart,.add-to-cart-button,#AddToCart",
    cssVariantSwitchSelector: {{ cssVariantSwitchSelector | json }} || "",
    cssQuantityInputSelector: {{ cssQuantityInputSelector | json }} || "",
    cssProductThumbnailImageSelector: {{ cssProductThumbnailImageSelector | json }} || "",
    cssProductLargePreviewImagesSelector: {{ cssProductLargePreviewImagesSelector | json }} || "",
    cssCartItemSelector: {{ cssCartItemSelector | json }} || "",
    cssCartItemLinkSelector: {{ cssCartItemLinkSelector | json }} || "",
    cssCartItemImageSelector: {{ cssCartItemImageSelector | json }} || "",
    cssCartItemQuantitySelector: {{ cssCartItemQuantitySelector | json }} || "",
    cssCartItemListSelector: {{ cssCartItemListSelector | json }} || ""
  },
  captions: {
    addToBasket: {{ addToBasketText | json }} || "Add to basket",
    designNow: {{ designNowText | json }} || "Design now",
    saveBasketItem: {{ saveBasketItemText | json }} || "Save",
    cancel: {{ cancelButtonText | json }} || "Cancel",
    loadingButtonText: {{ loadingButtonText | json }} || "Loading ...",
    cartEditButton: {{ cartEditButtonText | json }} || "Edit",
    advancedButtonText: {{ advancedButtonText | json }} || "Advanced Editing"
  },
  useVariantIdField: {% if useVariantIdField != blank  %} {{ useVariantIdField | json }} {% else %} false {% endif %},
  priceFormat: "{{ shop.money_with_currency_format }}",{%comment%}shop.money_format{%endcomment%}
  displayProductName: {% if displayProductName != blank  %} {{ displayProductName | json }} {% else %} false {% endif %},
  editorUrlParams: {},
  redirectToCartAfterAddToBasketClick: {% if redirectToCartAfterAddToBasketClick != blank  %} {{ redirectToCartAfterAddToBasketClick | json }} {% else %} true {% endif %},
  slimUi: {
    shopThemeName: {{ shopThemeName | json }} || "",
    formInsertPosition: {{ formInsertPosition | json}} || 4,
    carouselMode: {% if carouselMode != blank  %} {{ carouselMode | json }} {% else %} false {% endif %},
    buttonClasses: {{ buttonClasses | json }},
    maxProductThumbnails: {% if maxProductThumbnails != blank  %} {{ maxProductThumbnails | json }} {% else %} 4 {% endif %},
    hasFullEditor: {% if hasFullEditor != blank  %} {{ hasFullEditor | json }} {% else %} false {% endif %},
    maxThumbnailHeight: {{ maxThumbnailHeight | json }} || null,
    ignoreFirstRenderCall: {% if ignoreFirstRenderCall != blank  %} {{ ignoreFirstRenderCall | json }} {% else %} false {% endif %}
  },
  getShopLevelSettings: () => {
    if(printessSettings.shopLevelSettings) {
      return printessSettings.shopLevelSettings;
    }

    {% if shop.metafields.printess.settings.value != blank %}
      try {
        const json = {{shop.metafields.printess.settings.value | json}};

        if(json) {
          printessSettings.shopLevelSettings = json;
          return json;
        }
      } catch {

      }
    {% endif %}

    return {};
  }
};

if(printessSettings.additionalProductMetaFields && typeof printessSettings.additionalProductMetaFields === "string") {
  try {
    printessSettings.additionalProductMetaFields = JSON.parse(printessSettings.additionalProductMetaFields);
  } catch {
    printessSettings.additionalProductMetaFields = printessSettings.additionalProductMetaFields.split(",");
  }

  if(!Array.isArray(printessSettings.additionalProductMetaFields)) {
    printessSettings.additionalProductMetaFields = null;
    console.error("PrintessIntegration: Invalid product meta data. Skipping.");
  }
}
{% endif %}

