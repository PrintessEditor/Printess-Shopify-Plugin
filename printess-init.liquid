document.addEventListener('DOMContentLoaded', () => {
  setTimeout(function() {
    {% if disableProductIntegration != true %}
      PrintessIntegrationLauncher.initialize(printessSettings);
    {% endif %}

    {% if disableCartIntegration != true %}
      PrintessShopifyCartIntegration.initializeCartPage(printessSettings);
    {% endif %}
  }, 1)
});
</script>